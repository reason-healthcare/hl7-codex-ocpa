    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "fhir-kit-client": "^2.0.1"
  }
