# OGCA Reference Application — Environment Variables
# Copy to .env.local in each app directory and adjust as needed.

# FHIR server base URL
FHIR_BASE_URL=http://localhost:8080/fhir

# Jane Smith fixture patient ID (set after running fixtures/load-fixtures.sh)
JANE_SMITH_PATIENT_ID=jane-smith

# Set to "true" to bypass SMART auth (Phases 1-3)
SMART_AUTH_BYPASS=true
