       ] ;
       fhir:name [ fhir:v "Example Regimen Definition: TH (Paclitaxel + Trastuzumab, Weekly)" ] ;
       fhir:description [ fhir:v "Canonical definition of weekly Paclitaxel (80 mg/m² IV) plus Trastuzumab\n(4 mg/kg loading, then 2 mg/kg IV) for 12 weeks in adjuvant HER2-positive early breast\ncancer. Demonstrates RegimenIntentExtension (adjuvant), RegimenTreatmentLineExtension\n(first-line), and RegimenDiseaseContextExtension." ] ;
