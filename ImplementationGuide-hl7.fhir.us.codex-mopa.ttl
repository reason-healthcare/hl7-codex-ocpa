           a fhir:String ;
           fhir:v "Condition"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/Condition/MOPABreastCancerConditionExample> ;
         fhir:reference [ fhir:v "Condition/MOPABreastCancerConditionExample" ]
       ] ;
       fhir:name [ fhir:v "Example: Primary HER2+ Breast Cancer (Stage IIB)" ] ;
       fhir:description [ fhir:v "Invasive ductal carcinoma of right breast, HER2-positive,\nStage IIB (T2 N1 M0), diagnosed November 2025. Referenced by all MOPA examples\ndepicting Jane Smith's adjuvant treatment course." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "MedicationRequest"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/MedicationRequest/TrastuzumabMedRequestPHD> ;
         fhir:reference [ fhir:v "MedicationRequest/TrastuzumabMedRequestPHD" ]
       ] ;
       fhir:name [ fhir:v "Example: Trastuzumab MedicationRequest (PHD regimen, draft)" ] ;
       fhir:description [ fhir:v "Draft MedicationRequest for trastuzumab IV q21d in PHD regimen." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "MedicationRequest"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/MedicationRequest/TrastuzumabMedRequestTH> ;
         fhir:reference [ fhir:v "MedicationRequest/TrastuzumabMedRequestTH" ]
       ] ;
       fhir:name [ fhir:v "Example: Trastuzumab MedicationRequest (TH regimen, draft)" ] ;
       fhir:description [ fhir:v "Draft MedicationRequest for trastuzumab IV weekly in TH regimen." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/StructureDefinition/line-of-therapy-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/line-of-therapy-observation" ]
       ] ;
       fhir:name [ fhir:v "Line of Therapy Observation" ] ;
       fhir:description [ fhir:v "An Observation that documents the ordinal line of systemic anti-cancer\ntherapy a patient is currently receiving or has received for a given cancer diagnosis.\n\nThis observation is a required patient data element for oncology prior authorization:\nmost metastatic and recurrent cancer regimen policies are line-of-therapy dependent.\n\nObservation.code uses the local MOPA code system code `line-of-therapy` as a placeholder.\nA migration request for a LOINC code will be submitted before mCODE STU5.\n\nObservation.value[x] SHALL be a CodeableConcept drawn from TreatmentLineVS.\nThe focus SHALL reference the primary cancer Condition for which this line applies.\n\n**mCODE Migration Candidate** — Proposed for inclusion in mCODE STU5." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/CodeSystem/ocpa-codes> ;
         fhir:reference [ fhir:v "CodeSystem/ocpa-codes" ]
       ] ;
       fhir:name [ fhir:v "MOPA Local Code System" ] ;
       fhir:description [ fhir:v "Local codes defined by the MOPA IG for concepts that do not yet have\nan established representation in LOINC, SNOMED CT, or mCODE. These codes are migration\ncandidates and should be retired in favor of standard codes as they become available." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CapabilityStatement"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/CapabilityStatement/ocpa-crd-client> ;
         fhir:reference [ fhir:v "CapabilityStatement/ocpa-crd-client" ]
       ] ;
       fhir:name [ fhir:v "Oncology CRD Client Capability Statement" ] ;
       fhir:description [ fhir:v "Capability Statement for systems acting as an **Oncology CRD Client**\n(e.g., an EHR or oncology ordering system).  A conformant client claims support for\nthe Da Vinci CRD oncology profile defined in this IG by meeting the requirements below." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CapabilityStatement"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/CapabilityStatement/ocpa-crd-service> ;
         fhir:reference [ fhir:v "CapabilityStatement/ocpa-crd-service" ]
       ] ;
       fhir:name [ fhir:v "Oncology CRD Service Capability Statement" ] ;
       fhir:description [ fhir:v "Capability Statement for systems acting as an **Oncology CRD Service**\n(e.g., a payer or prior-authorization platform).  A conformant service claims support for\nthe Da Vinci CRD oncology profile defined in this IG by meeting the requirements below." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/StructureDefinition/regimen-days-of-cycle> ;
         fhir:reference [ fhir:v "StructureDefinition/regimen-days-of-cycle" ]
       ] ;
       fhir:name [ fhir:v "Regimen Days of Cycle" ] ;
       fhir:description [ fhir:v "Specifies the days within a repeating treatment cycle on which a\nregimen action is to be performed. Semantically identical to the HL7 core extension\n[timing-daysOfCycle](http://hl7.org/fhir/StructureDefinition/timing-daysOfCycle),\nbut with context broadened to `Timing` so it can be applied to nested\n`RequestGroup.action.action` elements used in phased multi-agent regimens.\n\nThe cycle length is expressed via `Timing.repeat.period` / `Timing.repeat.periodUnit`\non the same element. Day numbering starts at 1 (day 1 = first day of cycle 1).\n\nThis extension is a migration candidate for inclusion in the HL7 FHIR Extensions\npack with an expanded context. See [regimen-model.html](regimen-model.html)." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/StructureDefinition/ocpa-regimen-disease-context> ;
         fhir:reference [ fhir:v "StructureDefinition/ocpa-regimen-disease-context" ]
       ] ;
       fhir:name [ fhir:v "Regimen Disease Context" ] ;
       fhir:description [ fhir:v "Identifies the cancer type or specific cancer condition for which this\nanti-cancer regimen is defined. May be a coded value (e.g., SNOMED CT cancer concept)\nfor use on canonical PlanDefinition definitions, or a reference to the patient's primary\ncancer Condition for use on RequestGroup instances.\n\n**mCODE Migration Candidate** — Proposed for inclusion in mCODE STU5 as an extension\non anti-cancer regimen profiles." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/StructureDefinition/ocpa-regimen-intent> ;
         fhir:reference [ fhir:v "StructureDefinition/ocpa-regimen-intent" ]
       ] ;
       fhir:name [ fhir:v "Regimen Intent" ] ;
       fhir:description [ fhir:v "The clinical intent of the anti-cancer regimen (e.g., curative,\npalliative, adjuvant, neoadjuvant, supportive). Applies to both the canonical regimen\ndefinition (PlanDefinition) and the patient-specific ordered instance (RequestGroup).\n\n**mCODE Migration Candidate** — Proposed for inclusion in mCODE STU5 as an extension\non anti-cancer regimen profiles." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/ValueSet/regimen-intent-vs> ;
         fhir:reference [ fhir:v "ValueSet/regimen-intent-vs" ]
       ] ;
       fhir:name [ fhir:v "Regimen Intent Value Set" ] ;
       fhir:description [ fhir:v "The clinical intent of an anti-cancer regimen. All codes are drawn from\nthe SNOMED CT \\\"Intents (nature of procedure values)\\\" hierarchy (363675004).\n\n**mCODE Migration Candidate** — Proposed for mCODE STU5." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/StructureDefinition/ocpa-regimen-treatment-line> ;
         fhir:reference [ fhir:v "StructureDefinition/ocpa-regimen-treatment-line" ]
       ] ;
       fhir:name [ fhir:v "Regimen Treatment Line" ] ;
       fhir:description [ fhir:v "The ordinal line of systemic anti-cancer therapy for which this\nregimen is defined (e.g., first-line, second-line, maintenance). Applies to both the\ncanonical regimen definition (PlanDefinition) and the patient-specific ordered instance\n(RequestGroup).\n\nNote: This extension captures the regimen's *designed* treatment line. To document the\npatient's *current* line of therapy as a clinical observation, use LineOfTherapyObservation.\n\n**mCODE Migration Candidate** — Proposed for inclusion in mCODE STU5 as an extension\non anti-cancer regimen profiles." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/CodeSystem/treatment-line-cs> ;
         fhir:reference [ fhir:v "CodeSystem/treatment-line-cs" ]
       ] ;
       fhir:name [ fhir:v "Treatment Line Code System" ] ;
       fhir:description [ fhir:v "Ordinal codes representing the line of systemic anti-cancer therapy.\nThese codes are used in the TreatmentLineVS value set and on the LineOfTherapyObservation\nand regimen profiles.\n\n**mCODE Migration Candidate** — These codes are proposed for adoption in mCODE STU5\nor as a SNOMED CT extension request. Once standard codes are available, this code\nsystem should be deprecated." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ValueSet"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/codex-mopa/ValueSet/treatment-line-vs> ;
         fhir:reference [ fhir:v "ValueSet/treatment-line-vs" ]
       ] ;
       fhir:name [ fhir:v "Treatment Line Value Set" ] ;
       fhir:description [ fhir:v "Codes representing the ordinal line of systemic anti-cancer therapy.\nUsed in LineOfTherapyObservation.valueCodeableConcept and the RegimenTreatmentLine extension.\n\n**mCODE Migration Candidate** — Proposed for mCODE STU5." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] ) ;
