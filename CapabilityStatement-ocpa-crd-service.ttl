     ] [
       fhir:system [ fhir:v "email" ] ;
       fhir:value [ fhir:v "ciclist@lists.HL7.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "Capability Statement for systems acting as an **Oncology CRD Service**\n(e.g., a payer or prior-authorization platform).  A conformant service claims support for\nthe Da Vinci CRD oncology profile defined in this IG by meeting the requirements below."] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [
         fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ;
         fhir:l <urn:iso:std:iso:3166>
       ] ;
       fhir:code [ fhir:v "US" ] ;
       fhir:display [ fhir:v "United States of America" ]
     ] )
  ] ) ; # 
  fhir:kind [ fhir:v "requirements"] ; # 
  fhir:fhirVersion [ fhir:v "4.0.1"] ; # 
  fhir:format ( [ fhir:v "json"] [ fhir:v "xml"] ) ; # 
  fhir:implementationGuide ( [
     fhir:v "http://hl7.org/fhir/us/codex-ocpa/ImplementationGuide/hl7.fhir.us.codex-ocpa"^^xsd:anyURI ;
     fhir:l <http://hl7.org/fhir/us/codex-ocpa/ImplementationGuide/hl7.fhir.us.codex-ocpa>
  ] [
     fhir:v "http://hl7.org/fhir/us/davinci-crd/ImplementationGuide/hl7.fhir.us.davinci-crd"^^xsd:anyURI ;
     fhir:l <http://hl7.org/fhir/us/davinci-crd/ImplementationGuide/hl7.fhir.us.davinci-crd>
  ] ) ; # 
  fhir:rest ( [
     fhir:mode [ fhir:v "server" ] ;
     fhir:documentation [ fhir:v "A conformant Oncology CRD Service SHALL:\n\n1. Be capable of evaluating the selected anti-cancer regimen `RequestGroup` and resolving its\n   instantiated `PlanDefinition`.\n2. Use the referenced or included `DataRequirement` entries to determine whether the supplied\n   patient context is sufficient for pre-approval evaluation.\n3. Return a DTR launch card when required patient context is missing.\n4. Support at least one cancer-specific `Library` conforming to `OncologyDataRequirementsLibrary`." ] ;
     fhir:resource ( [
       fhir:type [ fhir:v "RequestGroup" ] ;
       fhir:supportedProfile ( [
         fhir:v "http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/anticancer-regimen-requestgroup"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/anticancer-regimen-requestgroup>
       ] ) ;
       fhir:documentation [ fhir:v "SHALL resolve and evaluate RequestGroup resources received in CDS Hooks context.draftOrders." ] ;
       fhir:interaction ( [
         fhir:code [ fhir:v "read" ]
       ] )
     ] [
       fhir:type [ fhir:v "PlanDefinition" ] ;
       fhir:supportedProfile ( [
         fhir:v "http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/anticancer-regimen-plandefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/anticancer-regimen-plandefinition>
       ] ) ;
       fhir:documentation [ fhir:v "SHALL resolve PlanDefinition referenced by RequestGroup.instantiatesCanonical." ] ;
       fhir:interaction ( [
         fhir:code [ fhir:v "read" ]
       ] )
     ] [
       fhir:type [ fhir:v "Library" ] ;
       fhir:supportedProfile ( [
         fhir:v "http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/oncology-data-requirements-library"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/us/codex-ocpa/StructureDefinition/oncology-data-requirements-library>
       ] ) ;
       fhir:documentation [ fhir:v "SHALL support at least one cancer-specific Library conforming to OncologyDataRequirementsLibrary." ] ;
       fhir:interaction ( [
         fhir:code [ fhir:v "read" ]
       ] [
         fhir:code [ fhir:v "search-type" ]
       ] )
     ] )
  ] ) . # 

